#!/usr/bin/env bash
set -e

echo "Running pre-commit checks..."

# Format check
if ! cargo fmt --all -- --check 2>/dev/null; then
    echo "error: formatting issues detected. Run 'cargo fmt --all' to fix."
    exit 1
fi

# Lint check — `--all-targets --all-features` mirrors the CI Lint job
# exactly. Without these flags the hook misses test/example targets and
# the `__test_utils` feature surface, producing the local-pass-CI-fail
# trap that MEMORY.md's `ghas_clippy_extra_lints.md` documents.
if ! cargo clippy --workspace --all-targets --all-features -- -D warnings 2>/dev/null; then
    echo "error: clippy warnings detected."
    exit 1
fi

# Rustdoc lint check — `-D warnings` for rustdoc catches broken
# intra-doc links and missing-doc warnings before docs.rs renders a
# broken page. Mirrors the CI Lint job's third step exactly. Phase 2a
# Task 9 introduced the first slip past the pre-fix hook (PR #177).
if ! RUSTDOCFLAGS="-D warnings" cargo doc --workspace --no-deps --all-features 2>/dev/null; then
    echo "error: rustdoc warnings detected (likely broken intra-doc links)."
    exit 1
fi

# Typos check — mirrors CI's `Spell check` job
# (`.github/workflows/typos.yml`, crate-ci/typos v1.46.3). Allowlist
# for domain terms lives in `_typos.toml`; legitimate abbreviations
# go in `[default.extend-words]` rather than getting fixed.
if ! command -v typos > /dev/null 2>&1; then
    echo "error: 'typos' CLI not found on PATH."
    echo "  install: cargo install typos-cli"
    exit 1
fi
# Don't suppress typos' stderr — its diagnostic output (file:line +
# suggested fix) IS the actionable signal; suppressing it would force
# the contributor to re-run manually. Diverges from the established
# `2>/dev/null` pattern on fmt/clippy/rustdoc because those tools'
# `--check` modes are quiet-on-success; typos is quiet-on-success too
# but its failure output is the diagnostic.
if ! typos .; then
    echo "error: spelling issues detected (see above)."
    echo "  for legitimate domain terms, add to '_typos.toml' [default.extend-words]."
    exit 1
fi

# Orphan-doc-TODO check — flags a bare TODO/FIXME left in a `///`/`//!` doc
# comment (no tracking ref), the mechanically-detectable slice of the doc-rot
# class PR #594 hit repeatedly. Scans staged .rs only (its default); narrow on
# purpose so it stays zero-noise — prose like "placeholder"/"stub" is NOT flagged
# (legitimate domain vocabulary; that judgment is a review step, not a grep).
# The script prints its own diagnostic + remediation, so the hook just relays
# the exit status (no redundant message, unlike typos above which adds a hint).
# Hook-only (not a CI job) on purpose: a CI step needs a ruleset required-check
# entry that orphans on rename (see `feedback_ci_job_rename_orphans_ruleset_check.md`,
# the same breadcrumb ci.yml / format-docs.yml cite); this gate is no weaker than
# the fmt/clippy/typos checks above, which are hook-only too.
if ! scripts/lint-orphan-doc-todos.sh; then
    exit 1
fi

echo "Pre-commit checks passed."
