+    let (global_strip, _class_strip) = read_strip_data_flags(cur, asset_path)?;
+    if global_strip & STRIP_FLAG_EDITOR_DATA == 0 {
+        return Err(fault(
+            asset_path,
+            AssetParseFault::TextureEditorDataNotStripped,
+        ));
+    }
