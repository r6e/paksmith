#!/usr/bin/env bash
set -e

echo "Running pre-commit checks..."

# Format check
if ! cargo fmt --all -- --check 2>/dev/null; then
    echo "error: formatting issues detected. Run 'cargo fmt --all' to fix."
    exit 1
fi

# Lint check — `--all-targets --all-features` mirrors the CI Lint job
# exactly. Without these flags the hook misses test/example targets and
# the `__test_utils` feature surface, producing the local-pass-CI-fail
# trap that MEMORY.md's `ghas_clippy_extra_lints.md` documents.
if ! cargo clippy --workspace --all-targets --all-features -- -D warnings 2>/dev/null; then
    echo "error: clippy warnings detected."
    exit 1
fi

# Rustdoc lint check — `-D warnings` for rustdoc catches broken
# intra-doc links and missing-doc warnings before docs.rs renders a
# broken page. Mirrors the CI Lint job's third step exactly. Phase 2a
# Task 9 introduced the first slip past the pre-fix hook (PR #177).
if ! RUSTDOCFLAGS="-D warnings" cargo doc --workspace --no-deps --all-features 2>/dev/null; then
    echo "error: rustdoc warnings detected (likely broken intra-doc links)."
    exit 1
fi

echo "Pre-commit checks passed."
